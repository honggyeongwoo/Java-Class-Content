
public class OperatorTest2 {

	public static void main(String[] args) {
		
		int 좋아요 = 99;
		System.out.println("현재 좋아요: " + 좋아요 );
		
		System.out.println(좋아요 >= 100 ?
				"축하드려요 인기게시글 이네요" :
				"분발하세요");
		
		boolean 결과 = 좋아요 >= 100;
		System.out.println("결과: " + 결과);	
		
		++좋아요;
		
		System.out.println("현재 좋아요2: " + 좋아요);
		
		System.out.println(좋아요 >= 100 ?
							"축하드려요 인기게시글 이네요" :
							"분발하세요");	
				
		결과 = 좋아요 >= 100;
		System.out.println("결과: " + 결과);	

	}

}
