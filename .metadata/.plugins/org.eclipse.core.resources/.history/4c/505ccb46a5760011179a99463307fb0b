
public class ControlTest {

	public static void main(String[] args) {

		boolean 로그인 = false;
		
		if(로그인) {
			System.out.println("로그인 성공!");
		}else {
			System.out.println("로그그인인 실패~");
		}
		
		//-----------------------------------------------
		int 나이 = 20;
		
		if (나이 >= 20) {
			System.out.println("성인 이네요");
		}else {
			System.out.println("저런저런 아직입니다~");
		}
		//-----------------------------------------------			
		int 재고 = 0;
		
		if (재고 <= 0) {
			System.out.println("재고가 없습니다!!");
		}else {
			System.out.println("아직 재고가 있습니다.");
		}
		//-----------------------------------------------
		
		}
	}


